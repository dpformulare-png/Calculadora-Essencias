                    { name: 'Manhã Cítrica', category: 'Cítrico', top: 'Limão Siciliano, Grapefruit', body: 'Lavanda', base: 'Cedro', result: 'Fresco e energizante' },
                    { name: 'Noite de Inverno', category: 'Amadeirado', top: 'Eucalipto', body: 'Lavanda', base: 'Cedro, Vetiver', result: 'Aconchegante e relaxante' },
                    { name: 'Oriente Místico', category: 'Oriental', top: 'Laranja Doce', body: 'Ylang Ylang', base: 'Âmbar, Patchouli', result: 'Exótico e sensual' }
                ],
                sale: { size: '', clientName: '', clientEmail: '', clientPhone: '', notes: '' },
