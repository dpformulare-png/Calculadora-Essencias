                newStockItem: { name: '', category: 'Essências', quantity: 0, unit: 'mL', minStock: 100 },
                activeCategory: 'Todos',

                // ERP STATE
                erpTab: 'dashboard',
                erpMenuItems: [
                    { id: 'dashboard', label: 'Dashboard', icon: 'layout-dashboard', desc: 'Visão geral e KPIs' },
                    { id: 'start', label: 'Início / Assistido', icon: 'home', desc: 'Definição estratégica e recomendações' },
                    { id: 'finance', label: 'Calculadora', icon: 'calculator', desc: 'Precificação e break-even' },
                    { id: 'timeline', label: 'Cronograma', icon: 'calendar', desc: 'Geração automática de datas' },
                    { id: 'crm', label: 'CRM Palestrantes', icon: 'users', desc: 'Banco de talentos' },
                    { id: 'copy', label: 'Gerador de Copy', icon: 'pen-tool', desc: 'Textos prontos para redes' },
                    { id: 'database', label: 'Banco de Dados', icon: 'database', desc: 'Estrutura do sistema' }
                ],
                erpInputs: { theme: '', attendees: 0, budget: 0, type: 'basic' },
