                financeCalc: {
                    speaker: 0,
                    coffee: 0,
                    gifts: 0,
                    marketing: 0,
                    participants: 0,
                    profitMargin: 30
                },
                financeResults: {
                    totalCost: 0,
                    minPrice: 0,
                    idealPrice: 0,
                    totalProfit: 0
                },
                showFinanceModal: false,
                erpTimeline: { eventDate: '', tasks: [] },
                erpChecklists: { pre: [{ text: 'Palestrante confirmado e alinhado', checked: false }, { text: 'Sala reservada e infraestrutura testada', checked: false }, { text: 'Coffee break contratado', checked: false }, { text: 'Lista de presença criada', checked: false }, { text: 'Divulgação ativa (Ads/Posts)', checked: false }], during: [{ text: 'Recepção ativa 30min antes', checked: false }, { text: 'Suporte técnico (Som/Projetor)', checked: false }, { text: 'Registro de fotos/vídeo', checked: false }, { text: 'Controle de presença', checked: false }] },
                erpSpeakers: [],
                showSpeakerModal: false,
                newSpeaker: { name: '', phone: '', city: '', ticket: 0 },
                
                // NEW: Speaker Delete State
                showDeleteSpeakerModal: false,
                speakerToDeleteIndex: null,

                erpCopyData: { theme: '', speaker: '', date: '', link: '' },
                erpGeneratedCopy: { insta: '', whats: '', email: '' },
                erpKpis: { revenue: 0, revenueGrowth: 0, profit: 0, margin: 0, roi: 0, attendees: 0, attendeesGrowth: 0, attendanceRate: 0 },
                erpEvents: [],
                erpAlerts: { highRisk: [], attention: [] },
                erpMarketingData: [],

                init() {
                    this.loadFromStorage();
                    lucide.createIcons();
                },

                // CALCULATOR FUNCTIONS
                addEssence(nota) {
                    const varNameMap = { 'topo': 'selectedTop', 'corpo': 'selectedCorpo', 'fundo': 'selectedFundo' };
                    const varName = varNameMap[nota];
                    const essence = this[varName];
                    if (essence && !this.calcData.selections[nota].includes(essence)) {
                        if (this.calcData.selections[nota].length < 4) { this.calcData.selections[nota].push(essence); this[varName] = ''; }
                        else { alert('Máximo de 4 essências permitidas para esta nota.'); }
                    }
                },
                removeEssence(nota, index) { this.calcData.selections[nota].splice(index, 1); },
                getEssenceBreakdown() {
                    if (!this.calcData.totalAmount || this.calcData.totalAmount <= 0) return [];
                    const breakdown = [];
                    const isCandle = this.calcData.type === 'vela';
                    const totalEssence = isCandle ? this.calcData.totalAmount * 0.15 : this.calcData.totalAmount * 0.20;
                    const topoTotal = totalEssence * 0.15, corpoTotal = totalEssence * 0.15, fundoTotal = totalEssence * 0.70;
                    this.calcData.selections.topo.forEach(essence => breakdown.push({ name: essence, amount: (topoTotal / this.calcData.selections.topo.length).toFixed(2) }));
                    this.calcData.selections.corpo.forEach(essence => breakdown.push({ name: essence, amount: (corpoTotal / this.calcData.selections.corpo.length).toFixed(2) }));
                    this.calcData.selections.fundo.forEach(essence => breakdown.push({ name: essence, amount: (fundoTotal / this.calcData.selections.fundo.length).toFixed(2) }));
                    return breakdown;
                },
                getCurrentPresets() { return this.activeCategory === 'Todos' ? this.presets : this.presets.filter(p => p.category === this.activeCategory); },
                applyPreset(preset) {
                    this.calcData.selections.topo = preset.top.split(', ').map(s => s.trim());
                    this.calcData.selections.corpo = preset.body.split(', ').map(s => s.trim());
                    this.calcData.selections.fundo = preset.base.split(', ').map(s => s.trim());
                    this.calcTab = 1;
                },
                getTotalEssencesCount() { return this.calcData.selections.topo.length + this.calcData.selections.corpo.length + this.calcData.selections.fundo.length; },
                getAllSelectedEssences() { return [...this.calcData.selections.topo, ...this.calcData.selections.corpo, ...this.calcData.selections.fundo]; },
                getBasePrice() {
                    const prices = { '10': 25, '30': 45, '100_s': 65, '100_v': 70, '250_s': 95, '250_v': 105, '500': 150, '1000': 250 };
                    return prices[this.sale.size] || 0;
                },
                getExtraEssenceCost() { const total = this.getTotalEssencesCount(); return total <= 3 ? 0 : (total - 3) * 5; },
                getTotalPrice() { return this.getBasePrice() + this.getExtraEssenceCost(); },
                formatCurrency(value) { return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(value); },
                processSale() {
                    if (!this.sale.size) { alert('⚠️ Por favor, selecione um tamanho de frasco.'); return; }
                    if (this.getTotalEssencesCount() === 0) { alert('⚠️ Por favor, selecione pelo menos uma essência na Calculadora.'); return; }
                    if (!this.sale.clientName) { alert('⚠️ Por favor, informe o nome do cliente.'); return; }
                    const breakdown = this.getEssenceBreakdown();
                    const topoCount = this.calcData.selections.topo.length, corpoCount = this.calcData.selections.corpo.length;
                    const topo = breakdown.slice(0, topoCount).map((t, i) => ({ name: this.calcData.selections.topo[i], amount: parseFloat(t.amount) }));
                    const corpo = breakdown.slice(topoCount, topoCount + corpoCount).map((c, i) => ({ name: this.calcData.selections.corpo[i], amount: parseFloat(c.amount) }));
                    const fundo = breakdown.slice(topoCount + corpoCount).map((f, i) => ({ name: this.calcData.selections.fundo[i], amount: parseFloat(f.amount) }));
                    const newFolder = {
                        id: Date.now(), name: `${this.calcData.type.charAt(0).toUpperCase() + this.calcData.type.slice(1)} - ${this.sale.clientName}`,
                        date: new Date().toLocaleDateString('pt-BR'), productType: this.calcData.type, size: this.sale.size,
                        clientName: this.sale.clientName, clientEmail: this.sale.clientEmail, clientPhone: this.sale.clientPhone,
                        notes: this.sale.notes, totalPrice: this.getTotalPrice(), deliveryDate: '', deliveryTime: '',
                        essences: this.getAllSelectedEssences(), topo: topo, corpo: corpo, fundo: fundo
                    };
                    this.savedFolders.unshift(newFolder);
                    this.saveToStorage();
                    this.showSaleModal = true;
                    this.showToast = true; this.toastMessage = 'Venda Concluída!'; this.toastSubMessage = 'Pasta gerada com sucesso';
                    setTimeout(() => { this.showToast = false; }, 4000);
                },
                resetSale() {
                    this.sale = { size: '', clientName: '', clientEmail: '', clientPhone: '', notes: '' };
                    this.calcData.selections = { topo: [], corpo: [], fundo: [] }; this.calcData.totalAmount = null;
                    this.selectedTop = ''; this.selectedCorpo = ''; this.selectedFundo = '';
                },
                printSaleConfirmation() { window.print(); },
                openFolderModal(folder) { this.selectedFolder = { ...folder }; this.showFolderModal = true; },
                saveFolderDeliveryInfo() {
                    const index = this.savedFolders.findIndex(f => f.id === this.selectedFolder.id);
                    if (index !== -1) { this.savedFolders[index].deliveryDate = this.selectedFolder.deliveryDate; this.savedFolders[index].deliveryTime = this.selectedFolder.deliveryTime; this.saveToStorage(); }
                },
                printFolderDetails() { window.print(); },
                confirmDeleteFolder(index) {
                    const filteredFolders = this.getFilteredSavedFolders();
                    const folder = filteredFolders[index];
                    const realIndex = this.savedFolders.findIndex(f => f.id === folder.id);
                    this.folderToDelete = folder; this.folderToDeleteIndex = realIndex; this.showDeleteConfirmModal = true;
                },
                deleteFolderConfirmed() {
                    if (this.folderToDeleteIndex !== null) {
                        this.savedFolders.splice(this.folderToDeleteIndex, 1); this.saveToStorage();
                        this.showDeleteConfirmModal = false; this.folderToDelete = null; this.folderToDeleteIndex = null;
                        this.showToast = true; this.toastMessage = 'Pasta Excluída!'; this.toastSubMessage = 'A pasta foi removida com sucesso';
                        setTimeout(() => { this.showToast = false; }, 3000);
                    }
                },
                editStock(index) { this.newStockItem = { ...this.stock[index] }; this.editingStockIndex = index; this.showAddStockModal = true; },
                saveStockItem() {
                    if (!this.newStockItem.name) { alert('Por favor, informe o nome do item.'); return; }
                    if (this.editingStockIndex !== null) { this.stock[this.editingStockIndex] = { ...this.newStockItem }; this.editingStockIndex = null; }
                    else { this.stock.push({ ...this.newStockItem }); }
                    this.showAddStockModal = false; this.newStockItem = { name: '', category: 'Essências', quantity: 0, unit: 'mL', minStock: 100 };
                    this.saveToStorage();
                },
                deleteStock(index) { if (confirm('Tem certeza que deseja excluir este item do estoque?')) { this.stock.splice(index, 1); this.saveToStorage(); } },
                getFilteredSavedFolders() {
                    if (!this.searchSavedFolders) return this.savedFolders;
                    return this.savedFolders.filter(f => f.name.toLowerCase().includes(this.searchSavedFolders.toLowerCase()) || (f.clientName && f.clientName.toLowerCase().includes(this.searchSavedFolders.toLowerCase())));
                },
                loadFromStorage() {
                    const saved = localStorage.getItem('formulareData');
                    if (saved) { 
                        const data = JSON.parse(saved); 
                        if (data.savedFolders) this.savedFolders = data.savedFolders; 
                        if (data.stock) this.stock = data.stock; 
                        if (data.speakers) this.erpSpeakers = data.speakers; 
                    }
                },
                saveToStorage() { 
                    localStorage.setItem('formulareData', JSON.stringify({ 
                        savedFolders: this.savedFolders, 
                        stock: this.stock, 
                        speakers: this.erpSpeakers 
                    })); 
                },

                // ERP FUNCTIONS
                calculateRecommendations() {
                    const att = parseInt(this.erpInputs.attendees) || 0;
                    const budget = parseFloat(this.erpInputs.budget) || 0;
                    const type = this.erpInputs.type;
                    if (type === 'basic') this.erpRecommendations.coffee = 'Simples (Água + Biscoito)';
                    else if (type === 'premium') this.erpRecommendations.coffee = 'Premium (Finger foods + Bebidas)';
                    else this.erpRecommendations.coffee = 'Intermediário (Salgados + Café)';
                    if (att < 20) this.erpRecommendations.space = 'Sala de Reunião Pequena';
                    else if (att < 50) this.erpRecommendations.space = 'Auditório Médio / Sala de Aula';
                    else this.erpRecommendations.space = 'Auditório Principal / Espaço Externo';
                    const totalCostEst = budget + (att * 15);
                    const suggestedPrice = att > 0 ? Math.ceil((totalCostEst / att) * 1.3) : 0;
                    this.erpRecommendations.price = att > 0 ? `R$ ${suggestedPrice},00` : 'R$ 0,00';
                    this.erpRecommendations.level = type === 'basic' ? 'Básico' : (type === 'premium' ? 'Premium' : 'Estratégico');
                    if (budget < 500 && att > 30) { this.erpRiskLevel = 'high'; this.erpRiskLabel = 'Alto Risco Financeiro'; this.erpRiskMessage = 'Orçamento muito baixo para o número de participantes esperado.'; }
                    else if (att > 100) { this.erpRiskLevel = 'medium'; this.erpRiskLabel = 'Atenção: Grande Porte'; this.erpRiskMessage = 'Evento de grande porte requer aprovação da diretoria.'; }
                    else if (att === 0 && budget === 0) { this.erpRiskLevel = 'low'; this.erpRiskLabel = 'Aguardando dados'; this.erpRiskMessage = 'Preencha os dados do evento para análise de risco.'; }
                    else { this.erpRiskLevel = 'low'; this.erpRiskLabel = 'Baixo Risco'; this.erpRiskMessage = 'Evento dentro dos padrões seguros de execução.'; }
                },

                // NEW: Finance Calculator Modal Function - ONLY OPEN ON BUTTON CLICK
                calculateFinanceModal() {
                    // Calculate Total Fixed Cost (sum of all costs)
                    const totalCost = (parseFloat(this.financeCalc.speaker) || 0) + 
                                     (parseFloat(this.financeCalc.coffee) || 0) + 
                                     (parseFloat(this.financeCalc.gifts) || 0) + 
                                     (parseFloat(this.financeCalc.marketing) || 0);

                    // Get participants
                    const participants = parseInt(this.financeCalc.participants) || 0;
                    
                    // Get profit margin
                    const profitMargin = (parseFloat(this.financeCalc.profitMargin) || 0) / 100;

                    // Calculate Minimum Unit Price (total cost / participants, without profit)
                    const minPrice = participants > 0 ? totalCost / participants : 0;

                    // Calculate Ideal Price (total cost + profit margin) / participants
                    const totalWithProfit = totalCost * (1 + profitMargin);
                    const idealPrice = participants > 0 ? totalWithProfit / participants : 0;

                    // Calculate Total Profit
                    const totalProfit = totalWithProfit - totalCost;

                    // Update results
                    this.financeResults = {
                        totalCost: totalCost,
                        minPrice: minPrice,
                        idealPrice: idealPrice,
                        totalProfit: totalProfit
                    };

                    // ONLY show modal when button is clicked (not on input change)
                    this.showFinanceModal = true;
                    lucide.createIcons();
                },

                printFinanceResults() {
                    window.print();
                },

                calculateProfit(qty) {
                    const price = this.erpFinance.results.idealPrice;
                    const feeRate = this.erpFinance.costs.feePercent / 100;
                    const revenue = price * qty * (1 - feeRate);
                    return revenue - this.erpFinance.results.totalCost;
                },
                generateTimeline() {
                    if (!this.erpTimeline.eventDate) return;
                    const eventDate = new Date(this.erpTimeline.eventDate);
                    const tasks = [];
                    const addTask = (daysBefore, title, desc, owner) => {
                        const d = new Date(eventDate); d.setDate(d.getDate() - daysBefore);
                        tasks.push({ dateLabel: `D-${daysBefore} (${d.toLocaleDateString('pt-BR')})`, title: title, desc: desc, owner: owner, completed: false });
                    };
                    addTask(30, 'Definir Tema e Palestrante', 'Validar disponibilidade e tema com o mercado', 'Projetos');
                    addTask(25, 'Fechar Local e Data', 'Reservar sala e confirmar infraestrutura', 'Logística');
                    addTask(20, 'Abrir Vendas', 'Configurar plataforma (Sympla/Even3) e lançar', 'Financeiro');
                    addTask(15, 'Início Divulgação', 'Primeira onda de posts e e-mails', 'Marketing');
                    addTask(7, 'Reforço Marketing', 'Contagem regressiva e últimas vagas', 'Marketing');
                    addTask(2, 'Briefing Final', 'Alinhamento final com palestrante', 'Projetos');
                    addTask(1, 'Checklist Final', 'Testar som, projetor e coffee', 'Operacional');
                    addTask(0, 'Dia do Evento', 'Execução e Registro', 'Todos');
                    this.erpTimeline.tasks = tasks;
                },
                getProgress(list) { if (list.length === 0) return 0; const checked = list.filter(i => i.checked).length; return Math.round((checked / list.length) * 100); },
                generateCopy() {
                    const t = this.erpCopyData.theme || '[Tema]', s = this.erpCopyData.speaker || '[Palestrante]', d = this.erpCopyData.date || '[Data]', l = this.erpCopyData.link || '[Link]';
                    this.erpGeneratedCopy.insta = `🚀 Novo Minicurso Formulare!\n\n📚 Tema: ${t}\n👨‍🏫 Com ${s}\n🗓️ ${d}\n\nGaranta sua vaga e eleve seu nível profissional! 👇\n🔗 ${l}\n\n#Formulare #EducaçãoContinuada #Farmácia`;
                    this.erpGeneratedCopy.whats = `Olá! 👋\n\nTemos um convite especial para você.\n\n🎓 Minicurso: ${t}\n📅 ${d}\n🎤 Palestrante: ${s}\n\nÉ uma oportunidade imperdível de atualização.\n\nInscreva-se aqui: ${l}`;
                    this.erpGeneratedCopy.email = `Assunto: Convite Especial: Minicurso ${t}\n\nPrezado(a),\n\nA Formulare tem o prazer de convidá-lo para o minicurso "${t}", que contará com a expertise de ${s}.\n\n🗓️ Data: ${d}\n📍 Local: Online/Presencial\n\nPara mais informações e inscrições, acesse: ${l}\n\nAtenciosamente,\nEquipe Formulare`;
                },
                copyToClipboard(text) { navigator.clipboard.writeText(text); alert('Texto copiado para a área de transferência!'); },
                getRiskClass(risk) { return risk === 'high' ? 'bg-red-500 text-white' : (risk === 'medium' ? 'bg-yellow-500 text-white' : 'bg-green-500 text-white'); },
                getRiskLabel(risk) { return risk === 'high' ? '🔴 Alto' : (risk === 'medium' ? '🟡 Médio' : '🟢 Baixo'); },
                
                // Speaker Functions
                openSpeakerModal() {
                    this.newSpeaker = { name: '', phone: '', city: '', ticket: 0 };
                    this.showSpeakerModal = true;
                },
                
                saveSpeaker() {
                    if (!this.newSpeaker.name || this.newSpeaker.name.trim() === '') {
                        alert('Por favor, informe o nome do palestrante!');
                        return;
                    }
                    if (!this.newSpeaker.phone || this.newSpeaker.phone.trim() === '') {
                        alert('Por favor, informe o telefone!');
                        return;
                    }
                    if (!this.newSpeaker.city || this.newSpeaker.city.trim() === '') {
                        alert('Por favor, informe a cidade!');
                        return;
                    }
                    if (this.newSpeaker.ticket === null || this.newSpeaker.ticket === undefined || isNaN(this.newSpeaker.ticket)) {
                        alert('Por favor, informe o ticket médio!');
                        return;
                    }
                    
                    this.erpSpeakers.push({
                        id: Date.now(),
                        name: this.newSpeaker.name.trim(),
                        phone: this.newSpeaker.phone.trim(),
                        city: this.newSpeaker.city.trim(),
                        ticket: parseFloat(this.newSpeaker.ticket)
                    });
                    this.saveToStorage();
                    
                    this.newSpeaker = { name: '', phone: '', city: '', ticket: 0 };
                    this.showSpeakerModal = false;
                    
                    this.showToast = true;
                    this.toastMessage = 'Palestrante Cadastrado!';
                    this.toastSubMessage = 'Dados salvos com sucesso';
                    setTimeout(() => { this.showToast = false; }, 3000);
                    lucide.createIcons();
                },
                
                confirmDeleteSpeaker(index) {
                    this.speakerToDeleteIndex = index;
                    this.showDeleteSpeakerModal = true;
                },

                executeDeleteSpeaker() {
                    if (this.speakerToDeleteIndex !== null) {
                        this.erpSpeakers.splice(this.speakerToDeleteIndex, 1);
                        this.saveToStorage();
                        this.showDeleteSpeakerModal = false;
                        this.speakerToDeleteIndex = null;
                        this.showToast = true;
                        this.toastMessage = 'Palestrante Excluído!';
                        this.toastSubMessage = 'O palestrante foi removido com sucesso';
                        setTimeout(() => { this.showToast = false; }, 3000);
                        lucide.createIcons();
                    }
                }
            }
        }
    </script>
