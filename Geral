<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema Formulare – Gestão Unificada</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Montserrat', 'sans-serif'],
                    },
                    colors: {
                        primary: '#4A0404',
                        secondary: '#6B0E0E',
                        action: '#D32F2F',
                        light: '#F4F6F8',
                    }
                }
            }
        }
    </script>

    <style>
        :root {
            --vinho-escuro: #4A0404;
            --vinho-medio: #6B0E0E;
            --vermelho-acao: #D32F2F;
            --cinza-fundo: #F4F6F8;
            --branco: #FFFFFF;
            --sombra-suave: 0 4px 6px rgba(0,0,0,0.05);
            --sombra-forte: 0 20px 40px rgba(74, 4, 4, 0.15);
            --transicao: all 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Montserrat', sans-serif; background-color: var(--cinza-fundo); color: #333333; min-height: 100vh; overflow-x: hidden; }
        [x-cloak] { display: none !important; }

        /* HOME PAGE STYLES */
        .home-section { display: flex; flex-direction: column; min-height: 100vh; }
        .home-header { text-align: center; padding: 50px 20px 30px; background: linear-gradient(180deg, var(--branco) 0%, var(--cinza-fundo) 100%); }
        
        .logo-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
        }

        .logo-wrapper {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo-circle {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, var(--vinho-escuro) 0%, var(--vinho-medio) 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 20px rgba(74, 4, 4, 0.3);
            transition: var(--transicao);
        }

        .logo-circle:hover {
            transform: scale(1.05);
            box-shadow: 0 12px 30px rgba(74, 4, 4, 0.4);
        }

        .logo-f {
            font-family: 'Montserrat', sans-serif;
            font-weight: 800;
            font-size: 42px;
            color: var(--branco);
            line-height: 1;
            letter-spacing: -2px;
        }

        .logo-text {
            font-family: 'Montserrat', sans-serif;
            font-weight: 800;
            font-size: 32px;
            color: var(--vinho-escuro);
            letter-spacing: -1px;
            text-transform: uppercase;
        }

        .system-name { 
            font-size: 0.85rem; 
            text-transform: uppercase; 
            letter-spacing: 3px; 
            color: var(--vinho-medio); 
            font-weight: 600; 
            padding-top: 10px; 
            border-top: 2px solid var(--vinho-escuro); 
            display: inline-block; 
            margin-top: 15px; 
        }

        .hero { text-align: center; max-width: 900px; margin: 0 auto; padding: 40px 20px 60px; }
        .hero h1 { font-size: 2.8rem; font-weight: 700; color: var(--vinho-escuro); margin-bottom: 20px; line-height: 1.2; }
        .hero p { font-size: 1.2rem; color: #888888; font-weight: 400; line-height: 1.7; max-width: 700px; margin: 0 auto; }
        .main-content { flex: 1; display: flex; justify-content: center; align-items: flex-start; padding: 0 20px 60px; }
        .blocks-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; width: 100%; max-width: 1100px; }
        .block-card { background: var(--branco); border-radius: 16px; padding: 50px 40px; text-decoration: none; color: inherit; box-shadow: var(--sombra-suave); transition: var(--transicao); border: 1px solid rgba(74, 4, 4, 0.08); display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; overflow: hidden; cursor: pointer; }
        .block-card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 5px; background: linear-gradient(90deg, var(--vinho-escuro), var(--vermelho-acao)); transition: var(--transicao); }
        .block-card::after { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at center, rgba(211, 47, 47, 0.03) 0%, transparent 70%); opacity: 0; transition: var(--transicao); }
        .block-icon { width: 80px; height: 80px; background: linear-gradient(135deg, var(--vinho-escuro) 0%, var(--vinho-medio) 100%); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin-bottom: 30px; transition: var(--transicao); box-shadow: 0 8px 20px rgba(74, 4, 4, 0.2); }
        .block-icon i { font-size: 2.2rem; color: var(--branco); transition: var(--transicao); }
        .block-title { font-size: 1.6rem; font-weight: 700; color: var(--vinho-escuro); margin-bottom: 15px; transition: var(--transicao); }
        .block-desc { font-size: 1rem; color: #666; margin-bottom: 30px; line-height: 1.6; max-width: 350px; }
        .tags-wrapper { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; position: relative; z-index: 1; }
        .tag { background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%); color: #555; padding: 8px 16px; border-radius: 25px; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.5px; border: 1px solid rgba(0,0,0,0.05); transition: var(--transicao); }
        .block-card:hover { transform: translateY(-12px); box-shadow: var(--sombra-forte); border-color: rgba(211, 47, 47, 0.3); }
        .block-card:hover::before { height: 6px; }
        .block-card:hover::after { opacity: 1; }
        .block-card:hover .block-icon { background: linear-gradient(135deg, var(--vermelho-acao) 0%, var(--vinho-escuro) 100%); transform: scale(1.08); box-shadow: 0 12px 30px rgba(211, 47, 47, 0.35); }
        .block-card:hover .block-icon i { transform: scale(1.1); }
        .block-card:hover .block-title { color: var(--vermelho-acao); }
        .block-card:hover .tag { background: linear-gradient(135deg, var(--vinho-escuro) 0%, var(--vinho-medio) 100%); color: var(--branco); border-color: transparent; }
        .home-footer { text-align: center; padding: 30px 20px; background: var(--branco); border-top: 1px solid #e5e5e5; }
        .home-footer p { font-size: 0.85rem; color: #888888; }

        /* CALCULATOR PAGE STYLES */
        .calculator-section { display: none; min-height: 100vh; background-color: #f9fafb; font-family: 'Montserrat', sans-serif; }
        .calculator-section.active { display: block; }
        .tab-active { border-bottom: 3px solid #4A0404; color: #4A0404; font-weight: 600; }
        .tab-inactive { border-bottom: 3px solid transparent; color: #6b7280; }
        .tab-inactive:hover { color: #6B0E0E; }
        .slide-in { animation: slideIn 0.4s ease-out; }
        @keyframes slideIn { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @media print { body * { visibility: hidden; } #printableArea, #printableArea * { visibility: visible; } #printableArea { position: absolute; left: 0; top: 0; width: 100%; } .no-print { display: none; } }

        /* ERP STYLES - UNIFIED WITH CALCULATOR */
        .erp-section { display: none; min-height: 100vh; background-color: #F4F6F8; font-family: 'Montserrat', sans-serif; overflow: hidden; }
        .erp-section.active { display: flex; }
        .erp-layout { display: flex; width: 100%; height: 100vh; overflow: hidden; }
        .erp-sidebar { flex-shrink: 0; transition: width 0.3s ease-in-out, opacity 0.3s ease-in-out; overflow: hidden; white-space: nowrap; }
        .erp-sidebar.collapsed { width: 0 !important; opacity: 0; }
        .erp-main { flex: 1; overflow-y: auto; overflow-x: hidden; transition: all 0.3s ease-in-out; }
        .card-hover { transition: all 0.3s ease; }
        .card-hover:hover { transform: translateY(-2px); box-shadow: 0 12px 24px -8px rgba(74, 4, 4, 0.15); }
        .bar-transition { transition: height 0.5s ease-out, width 0.5s ease-out; }
        .kanban-card { transition: all 0.2s ease; }
        .kanban-card:hover { transform: translateY(-2px); box-shadow: 0 8px 16px -4px rgba(74, 4, 4, 0.1); }
        .pulse-dot { animation: pulse 2s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

        /* Toggle Button */
        .sidebar-toggle {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 100;
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: left 0.3s ease-in-out;
        }
        .sidebar-toggle:hover { background: #f1f5f9; }
        .sidebar-toggle.expanded { left: 276px; }

        @media (max-width: 900px) {
            .blocks-grid { grid-template-columns: 1fr; gap: 30px; max-width: 500px; }
            .hero h1 { font-size: 2rem; }
            .block-card { padding: 40px 30px; }
            .sidebar-toggle.expanded { left: 20px; }
            .logo-text { font-size: 26px; }
            .logo-circle { width: 60px; height: 60px; }
            .logo-f { font-size: 36px; }
        }
        @media (max-width: 480px) {
            .hero h1 { font-size: 1.7rem; }
            .block-icon { width: 70px; height: 70px; }
            .block-icon i { font-size: 1.8rem; }
            .block-title { font-size: 1.4rem; }
            .logo-wrapper { flex-direction: column; }
            .logo-text { font-size: 24px; }
        }
    </style>
</head>
<body x-data="mainApp()">

    <!-- ========================================== -->
    <!-- 1. HOME PAGE                               -->
    <!-- ========================================== -->
    <div class="home-section" x-show="currentPage === 'home'" x-transition.opacity>
        <header class="home-header">
            <div class="logo-container">
                <div class="logo-wrapper">
                    <div class="logo-circle">
                        <span class="logo-f">f</span>
                    </div>
                    <span class="logo-text">Formulare</span>
                </div>
                <div class="system-name">Sistema de Gestão</div>
            </div>
        </header>

        <section class="hero">
            <h1>Gerencie projetos e formule decisões com inteligência</h1>
            <p>Acesse ferramentas para gestão de minicursos e desenvolvimento de produtos aromáticos</p>
        </section>

        <main class="main-content">
            <div class="blocks-grid">
                <div class="block-card" @click="navigateTo('erp')">
                    <div class="block-icon"><i class="fa-solid fa-chalkboard-user"></i></div>
                    <h2 class="block-title">Gestão de Mini Cursos</h2>
                    <p class="block-desc">Planeje, execute e analise eventos com controle financeiro, checklist e métricas</p>
                    <div class="tags-wrapper">
                        <span class="tag">+ Planejamento</span>
                        <span class="tag">+ Lucro</span>
                        <span class="tag">+ Organização</span>
                    </div>
                </div>

                <div class="block-card" @click="navigateTo('calculadora')">
                    <div class="block-icon"><i class="fa-solid fa-flask"></i></div>
                    <h2 class="block-title">Calculadora de Essências</h2>
                    <p class="block-desc">Crie formulações aromáticas com precisão e padronização</p>
                    <div class="tags-wrapper">
                        <span class="tag">Padronização</span>
                        <span class="tag">Escala</span>
                        <span class="tag">Controle</span>
                    </div>
                </div>
            </div>
        </main>

        <footer class="home-footer">
            <p>&copy; 2024 Formulare Systems. Todos os direitos reservados.</p>
        </footer>
    </div>

    <!-- ========================================== -->
    <!-- 2. CALCULATOR PAGE                         -->
    <!-- ========================================== -->
    <div class="calculator-section" :class="{ 'active': currentPage === 'calculadora' }">
        <header class="bg-white shadow-md sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="flex items-center gap-3">
                    <button @click="navigateTo('home')" class="text-primary hover:text-secondary transition mr-2" title="Voltar para Home">
                        <i class="fa-solid fa-arrow-left text-xl"></i>
                    </button>
                    <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center shadow-lg">
                        <span class="text-white font-bold text-2xl">f</span>
                    </div>
                    <h1 class="text-2xl font-bold text-primary tracking-tight">Formulare</h1>
                </div>
                <div class="flex items-center gap-2 bg-gray-100 p-1 rounded-lg">
                    <span class="text-xs font-semibold text-gray-500 uppercase mr-2">Perfil:</span>
                    <button @click="calcRole = 'vendas'" :class="calcRole === 'vendas' ? 'bg-white shadow text-primary' : 'text-gray-500 hover:text-gray-700'" class="px-3 py-1.5 rounded-md text-sm font-medium transition">Vendas</button>
                    <button @click="calcRole = 'projetos'" :class="calcRole === 'projetos' ? 'bg-white shadow text-primary' : 'text-gray-500 hover:text-gray-700'" class="px-3 py-1.5 rounded-md text-sm font-medium transition">Projetos</button>
                    <button @click="calcRole = 'admin'" :class="calcRole === 'admin' ? 'bg-white shadow text-primary' : 'text-gray-500 hover:text-gray-700'" class="px-3 py-1.5 rounded-md text-sm font-medium transition">Admin</button>
                </div>
            </div>
            <nav class="max-w-7xl mx-auto px-4 flex gap-8 overflow-x-auto">
                <template x-if="calcRole === 'vendas' || calcRole === 'projetos'">
                    <button @click="calcTab = 1" :class="calcTab === 1 ? 'tab-active' : 'tab-inactive'" class="pb-3 whitespace-nowrap transition">Calculadora</button>
                </template>
                <template x-if="calcRole === 'projetos'">
                    <button @click="calcTab = 2" :class="calcTab === 2 ? 'tab-active' : 'tab-inactive'" class="pb-3 whitespace-nowrap transition">Combinações</button>
                </template>
                <template x-if="calcRole === 'vendas' || calcRole === 'projetos' || calcRole === 'admin'">
                     <button @click="calcTab = 3" :class="calcTab === 3 ? 'tab-active' : 'tab-inactive'" class="pb-3 whitespace-nowrap transition">Orçamento & Venda</button>
                </template>
                <template x-if="calcRole === 'admin' || calcRole === 'projetos'">
                    <button @click="calcTab = 4" :class="calcTab === 4 ? 'tab-active' : 'tab-inactive'" class="pb-3 whitespace-nowrap transition">Estoque</button>
                </template>
                <button @click="calcTab = 5" :class="calcTab === 5 ? 'tab-active' : 'tab-inactive'" class="pb-3 whitespace-nowrap transition">Pastas Salvas</button>
            </nav>
        </header>

        <main class="max-w-7xl mx-auto px-4 py-8 min-h-screen">
            <!-- TAB 1: CALCULADORA -->
            <div x-show="calcTab === 1" x-transition.opacity class="space-y-6">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                    <h2 class="text-xl font-bold text-primary mb-4">Configuração do Produto</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de Produto</label>
                            <select x-model="calcData.type" class="w-full border-gray-300 rounded-lg shadow-sm focus:border-primary focus:ring focus:ring-primary/20 p-2.5 bg-white border">
                                <option value="vela">Vela (Cera de Coco)</option>
                                <option value="vareta">Aromatizador de Vareta</option>
                                <option value="spray">Spray Aromatizador</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <span x-text="calcData.type === 'vela' ? 'Peso Total (g)' : 'Volume Total (mL)'"></span>
                            </label>
                            <input type="number" x-model.number="calcData.totalAmount" class="w-full border-gray-300 rounded-lg shadow-sm focus:border-primary focus:ring focus:ring-primary/20 p-2.5 bg-white border" placeholder="0">
                        </div>
                    </div>
                    <div class="bg-gray-50 p-4 rounded-lg mb-6 text-sm">
                        <template x-if="calcData.type === 'vela'">
                            <div class="flex justify-between items-center">
                                <span>Composição: <span class="font-bold text-primary">15% Essência</span>, 85% Cera de Coco</span>
                                <span class="font-mono bg-white px-2 py-1 rounded border">Essência: <span x-text="(calcData.totalAmount * 0.15).toFixed(1)"></span>g</span>
                            </div>
                        </template>
                        <template x-if="calcData.type !== 'vela'">
                            <div class="flex flex-col gap-2">
                                <div class="flex justify-between">
                                    <span>Composição: <span class="font-bold text-primary">80% Base</span>, 20% Perfume</span>
                                    <span class="font-mono bg-white px-2 py-1 rounded border">Base: <span x-text="(calcData.totalAmount * 0.80).toFixed(1)"></span>mL</span>
                                </div>
                                <div class="text-xs text-gray-500 mt-1">O Perfume (20%) é dividido em: 15% Topo, 15% Corpo, 70% Fundo.</div>
                            </div>
                        </template>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="border rounded-lg p-4">
                            <h3 class="font-semibold text-gray-700 mb-2 flex justify-between">Notas de Topo (15%) <span class="text-xs bg-gray-200 text-gray-600 px-2 py-0.5 rounded-full" x-text="calcData.selections.topo.length + '/4'"></span></h3>
                            <select x-model="selectedTop" @change="addEssence('topo')" class="w-full text-sm border-gray-300 rounded p-2 mb-2 bg-white">
                                <option value="" disabled selected>Selecionar Essência...</option>
                                <template x-for="essence in essences.topo" :key="essence"><option :value="essence" x-text="essence"></option></template>
                            </select>
                            <div class="space-y-1">
                                <template x-for="(essence, index) in calcData.selections.topo" :key="index">
                                    <div class="flex justify-between items-center bg-gray-50 px-2 py-1 rounded text-xs">
                                        <span x-text="essence"></span>
                                        <button @click="removeEssence('topo', index)" class="text-red-500 hover:text-red-700 font-bold">&times;</button>
                                    </div>
                                </template>
                            </div>
                        </div>
                        <div class="border rounded-lg p-4">
                            <h3 class="font-semibold text-gray-700 mb-2 flex justify-between">Notas de Corpo (15%) <span class="text-xs bg-gray-200 text-gray-600 px-2 py-0.5 rounded-full" x-text="calcData.selections.corpo.length + '/4'"></span></h3>
                            <select x-model="selectedCorpo" @change="addEssence('corpo')" class="w-full text-sm border-gray-300 rounded p-2 mb-2 bg-white">
                                <option value="" disabled selected>Selecionar Essência...</option>
                                <template x-for="essence in essences.corpo" :key="essence"><option :value="essence" x-text="essence"></option></template>
                            </select>
                            <div class="space-y-1">
                                <template x-for="(essence, index) in calcData.selections.corpo" :key="index">
                                    <div class="flex justify-between items-center bg-gray-50 px-2 py-1 rounded text-xs">
                                        <span x-text="essence"></span>
                                        <button @click="removeEssence('corpo', index)" class="text-red-500 hover:text-red-700 font-bold">&times;</button>
                                    </div>
                                </template>
                            </div>
                        </div>
                        <div class="border rounded-lg p-4">
                            <h3 class="font-semibold text-gray-700 mb-2 flex justify-between">Notas de Fundo (70%) <span class="text-xs bg-gray-200 text-gray-600 px-2 py-0.5 rounded-full" x-text="calcData.selections.fundo.length + '/4'"></span></h3>
                            <select x-model="selectedFundo" @change="addEssence('fundo')" class="w-full text-sm border-gray-300 rounded p-2 mb-2 bg-white">
                                <option value="" disabled selected>Selecionar Essência...</option>
                                <template x-for="essence in essences.fundo" :key="essence"><option :value="essence" x-text="essence"></option></template>
                            </select>
                            <div class="space-y-1">
                                <template x-for="(essence, index) in calcData.selections.fundo" :key="index">
                                    <div class="flex justify-between items-center bg-gray-50 px-2 py-1 rounded text-xs">
                                        <span x-text="essence"></span>
                                        <button @click="removeEssence('fundo', index)" class="text-red-500 hover:text-red-700 font-bold">&times;</button>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>
                    <div x-show="calcData.totalAmount > 0" class="mt-8 bg-primary text-white p-6 rounded-xl shadow-lg">
                        <h3 class="text-lg font-bold mb-4 border-b border-white/20 pb-2">Resultado da Fórmula</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div>
                                <p class="opacity-80 text-sm mb-1">Base / Cera Necessária:</p>
                                <p class="text-3xl font-bold" x-text="calcData.type === 'vela' ? (calcData.totalAmount * 0.85).toFixed(1) + ' g' : (calcData.totalAmount * 0.80).toFixed(1) + ' mL'"></p>
                            </div>
                            <div>
                                <p class="opacity-80 text-sm mb-1">Total de Essência:</p>
                                <p class="text-3xl font-bold" x-text="calcData.type === 'vela' ? (calcData.totalAmount * 0.15).toFixed(1) + ' g' : (calcData.totalAmount * 0.20).toFixed(1) + ' mL'"></p>
                            </div>
                        </div>
                        <div class="mt-6 bg-white/10 p-4 rounded-lg">
                            <p class="font-semibold mb-2 text-sm uppercase tracking-wide">Detalhamento das Essências</p>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2 text-sm">
                                <template x-for="item in getEssenceBreakdown()" :key="item.name">
                                    <div class="flex justify-between border-b border-white/10 pb-1">
                                        <span x-text="item.name"></span>
                                        <span class="font-mono" x-text="item.amount + (calcData.type === 'vela' ? ' g' : ' mL')"></span>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TAB 2: COMBINAÇÕES -->
            <div x-show="calcTab === 2" x-transition.opacity class="space-y-6">
                <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                    <h2 class="text-xl font-bold text-primary mb-4">Biblioteca de Combinações</h2>
