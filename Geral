                    { name: 'Sândalo', category: 'Essências', quantity: 80, unit: 'mL', minStock: 100 },
                    { name: 'Cera de Coco', category: 'Insumos', quantity: 5, unit: 'kg', minStock: 2 },
                    { name: 'Base para Spray', category: 'Insumos', quantity: 10, unit: 'L', minStock: 5 },
                    { name: 'Base para Vareta', category: 'Insumos', quantity: 8, unit: 'L', minStock: 5 },
